# --- アプリランタイム（Vercel 等サーバレス） ---
# Supabase Project Settings → Database → Connection string → Transaction Pooler を推奨
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@[host]:6543/postgres

# Drizzle CLI（npm run db:push 等）は .env と .env.local を drizzle.config が読む（このリポ構成）。

# --- Drizzle マイグレーション（直結 / session ポート） ---
# 「Direct connection」の URI。`npm run db:migrate` / `npm run db:push` で使用
# 末尾に推奨: ?sslmode=require（無いと Windows 等で接続が長く止まることがある）
# トラブル時: ?sslmode=require&connect_timeout=15
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres?sslmode=require

# 任意: postgres.js コネクション上限の目安（既定 10）
# DATABASE_POOL_MAX=10

# --- Supabase Auth（ブラウザ・SSR・middleware） ---
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Storage の署名付きアップロード／読み取り（Route Handler のみ・ブラウザに含めない）
# R2 未設定時は Supabase Storage を使用。既存ファイルの読取・削除にも service role が必要
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# --- Cloudflare R2（推奨・新規アップロード先。Egress 回避）---
# 4 つすべて設定すると新規ファイルは R2、DB の bucket は R2_BUCKET_NAME になる
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=dango-assets
# ブラウザ直 PUT 用 CORS（バケット Settings → CORS）。例:
# AllowedOrigins: http://localhost:3000, https://your-app.vercel.app
# AllowedMethods: GET, PUT, HEAD
# AllowedHeaders: Content-Type, *
# MaxAgeSeconds: 3600

# Supabase Storage のみ使う場合のバケット名（R2 未設定時。private で「assets」を作成）
# SUPABASE_STORAGE_BUCKET=assets

# 受取リンク発行 API で claim URL のホストを固定したい場合（未設定時はリクエストの Origin）
# NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app

# --- リスナー向け WebAuthn（パスキー） ---
# 本番: rpID はサイトのホスト名（例: your-app.vercel.app）。origin は https URL
# 未設定時はローカル開発用の localhost 既定
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGIN=http://localhost:3000
# WEBAUTHN_RP_NAME=Dango Share Link
# リスナー用 HttpOnly セッション（未設定時は AUTH_SECRET を流用。本番は専用の十分長い乱数推奨）
# WEBAUTHN_SESSION_SECRET=

# メールの「6桁コード」ログイン: Supabase Dashboard → Authentication → Email Templates の
# Magic Link 用テンプレートに {{ .Token }} を含め、リンク本文ではなく OTP を送る設定にする。
# Google / Discord ログイン: Authentication → Providers で各プロバイダを有効化し、
# Redirect URLs に {NEXT_PUBLIC_APP_URL}/auth/callback を追加する。

# Step D: OAuth 風連携（任意）
# INTEGRATION_ALLOWED_CLIENT_IDS=dango-tools-dev,my-client
# INTEGRATION_REDIRECT_ORIGINS=http://localhost:3000,https://your-dango-app.vercel.app

# だんごツール（Gacha側）のフロントエンドベースURL（未指定時は https://dango-tool.vercel.app）
# NEXT_PUBLIC_DANGO_TOOL_URL=http://localhost:3001

# --- Step E: /api/v1/external/*（だんごツールからのブラウザ fetch 用 CORS） ---
# 未設定時は localhost の代表的 Origin のみ許可
# EXTERNAL_CORS_ORIGINS=http://localhost:3000,https://your-dango-static.pages.dev
# Idempotency キャッシュ TTL（ミリ秒・既定 86400000 = 24h）
# EXTERNAL_IDEMPOTENCY_TTL_MS=86400000
