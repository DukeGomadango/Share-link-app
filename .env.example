# --- アプリランタイム（Vercel 等サーバレス） ---
# Supabase Project Settings → Database → Connection string → Transaction Pooler を推奨（ポート 6543）
# 末尾に ?sslmode=require を付けてもよい（未指定時はアプリ側で付与）
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@[host]:6543/postgres?sslmode=require

# 本番 Dashboard 設定チェックリスト: docs/security-config-checklist.md
# 本番デプロイ後の設定確認: GET /api/health（環境変数・DB 接続の有無のみ返す）
# E2E: npm run test:e2e（詳細 docs/phase3-roadmap.md）
# E2E_FULL_STACK=1 … .env.local 込みで health が ok になること
# E2E_INTEGRATION_TOKEN= … 外部 API スモーク（任意・専用トークン推奨）

# Vercel Cron（/api/cron/purge-expired-assets）用。十分長い乱数を Production に設定
# CRON_SECRET=

# プラン上限の正: src/lib/workspace/plan-limits.ts（Free 2GB/90日、Pro 50GB/自動削除なし）
# Pro 手動昇格 SQL: docs/ops-production.md

# Drizzle CLI（npm run db:push 等）は .env と .env.local を drizzle.config が読む（このリポ構成）。

# --- Drizzle マイグレーション（直結 / session ポート） ---
# 「Direct connection」の URI。`npm run db:migrate` / `npm run db:push` で使用
# 末尾に推奨: ?sslmode=require（無いと Windows 等で接続が長く止まることがある）
# トラブル時: ?sslmode=require&connect_timeout=15
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres?sslmode=require

# 任意: postgres.js コネクション上限の目安（既定 10）
# DATABASE_POOL_MAX=10

# --- Supabase Auth（ブラウザ・SSR・middleware） ---
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# 管理用（将来のサーバー側 Supabase API 用。ファイル実体は R2 のみ）
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# --- Cloudflare R2（推奨・新規アップロード先。Egress 回避）---
# 4 つすべて設定すると新規ファイルは R2、DB の bucket は R2_BUCKET_NAME になる
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=dango-assets
# ブラウザ直 PUT 用 CORS（バケット Settings → CORS）。例:
# AllowedOrigins: http://localhost:3000, https://your-app.vercel.app
# AllowedMethods: GET, PUT, HEAD
# AllowedHeaders: Content-Type（"*" だけだと R2 で preflight 400 になることがある）
# SDK 更新後も古い署名 URL には checksum クエリが残るため、必要なら次も追加:
# x-amz-content-crc32, x-amz-sdk-checksum-algorithm, x-amz-checksum-crc32
# MaxAgeSeconds: 3600

# 本番オリジン（末尾スラッシュなし）。受取リンク・OAuth・SEO（metadataBase / sitemap / OGP）で使用
# NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app

# SEO・分析（任意）
# Google Search Console → 所有権確認 → HTML タグの content 値
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GA4 測定 ID（例: G-XXXXXXXXXX）
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- リスナー向け WebAuthn（パスキー） ---
# 本番: rpID はサイトのホスト名（例: your-app.vercel.app）。origin は https URL
# 未設定時はローカル開発用の localhost 既定
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGIN=http://localhost:3000
# WEBAUTHN_RP_NAME=Dango Share Link
# リスナー用 HttpOnly セッション（未設定時は AUTH_SECRET を流用。本番は専用の十分長い乱数推奨）
# WEBAUTHN_SESSION_SECRET=

# メールの「6桁コード」ログイン: Supabase Dashboard → Authentication → Email Templates の
# Magic Link 用テンプレートに {{ .Token }} を含め、リンク本文ではなく OTP を送る設定にする。
# Google / Discord ログイン: Authentication → Providers で各プロバイダを有効化し、
# Redirect URLs に {NEXT_PUBLIC_APP_URL}/auth/callback を追加する。

# Step D: OAuth 風連携（だんごツールから /settings/integrations/authorize）
# 本番は dango-tools-gacha とだんごツールの origin を必ず設定（未設定時は開発用 ID のみ）
# INTEGRATION_ALLOWED_CLIENT_IDS=dango-tools-gacha,dango-tools-dev
# INTEGRATION_REDIRECT_ORIGINS=http://localhost:3000,https://your-dango-app.vercel.app

# だんごツール（人数カウントアプリ）のフロントエンド URL。/gacha はだんごツール側のルート。
# シェアリンクが 3000 のとき、だんごツール dev は通常 3001。3000 を指定すると 404 になります。
# 未指定時: 本番 https://dango-tool.vercel.app / localhost では http://localhost:3001
# NEXT_PUBLIC_DANGO_TOOL_URL=http://localhost:3001

# --- Step E: /api/v1/external/*（だんごツールからのブラウザ fetch 用 CORS） ---
# 未設定時は localhost の代表的 Origin のみ許可
# EXTERNAL_CORS_ORIGINS=http://localhost:3000,https://your-dango-static.pages.dev
# Idempotency キャッシュ TTL（ミリ秒・既定 86400000 = 24h）
# EXTERNAL_IDEMPOTENCY_TTL_MS=86400000

# --- レート制限（本番推奨・フェーズ 1-D）---
# 未設定時はサーバレス各インスタンスのインメモリ制限（開発用）
# Upstash Redis → https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# --- Stripe（Phase 3c・テストは sk_test_ / 本番は sk_live_）---
# 開発者 → API キー / Webhook は CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# Dashboard → 商品 → 各 Price ID（docs/phase3-roadmap.md の料金表）
# STRIPE_PRICE_PRO_MONTHLY=price_xxx
# STRIPE_PRICE_PRO_YEARLY=price_xxx
# STRIPE_PRICE_SUPPORTER_MONTHLY=price_xxx
# STRIPE_PRICE_SUPPORTER_YEARLY=price_xxx
